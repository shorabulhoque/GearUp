model User {
    id       String     @id @default(uuid())
    email    String     @unique
    name     String
    password String
    role     UserRole   @default(CUSTOMER)
    status   UserStatus @default(ACTIVE)

    gearItems    GearItem[]    @relation("ProviderGear")
    rentalOrders RentalOrder[] @relation("CustomerRentals")
    reviews      Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
